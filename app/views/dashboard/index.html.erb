<div style="max-width: 800px; margin: 60px auto; font-family: sans-serif;">
  <h1>Welcome, <%= current_user.email %>!</h1>
  <p style="color: var(--small); margin-bottom: 24px;">You are successfully logged in.</p>

  <% if current_user.plan_active? %>
    <div style="background: var(--flash-notice-bg); border: 1px solid var(--flash-notice-border); color: var(--flash-notice-text); padding: 12px 16px; border-radius: 8px; margin-bottom: 20px;">
      Active Plan: <strong><%= current_user.plan.capitalize %></strong> — Expires at <%= current_user.plan_expires_at.strftime("%I:%M %p") %>
    </div>
  <% end %>

  <div style="display: flex; gap: 12px; flex-wrap: wrap;">
    <%= link_to "My Profile", profile_path,
        style: "padding: 10px 20px; background: #4f8ef7; color: white; border-radius: 6px; text-decoration: none;" %>

    <%= link_to "Pricing Plans", pricing_index_path,
        style: "padding: 10px 20px; background: #f59e0b; color: white; border-radius: 6px; text-decoration: none;" %>

    <% if current_user.admin? %>
      <%= link_to "Admin Panel", admin_users_path,
          style: "padding: 10px 20px; background: #e53935; color: white; border-radius: 6px; text-decoration: none;" %>
    <% end %>

    <%= button_to "Sign out", destroy_user_session_path, method: :delete,
        style: "padding: 10px 20px; background: #6b7280; color: white; border: none; border-radius: 6px; font-size: 15px; cursor: pointer;" %>
  </div>
</div>